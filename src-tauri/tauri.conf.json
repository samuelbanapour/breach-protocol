{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Breach Protocol",
  "version": "0.1.0",
  "identifier": "com.samuelbanapour.breachprotocol",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Breach Protocol — Cyber Defense",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Game",
    "shortDescription": "Cybersecurity tower-defense — defend the network or breach it.",
    "longDescription": "Breach Protocol is a cybersecurity strategy game. Defend the network as Blue Team, or breach it as a Red Hat hacker. Tower-defense both ways, 65 achievements.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
